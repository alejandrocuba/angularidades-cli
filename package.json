{
  "name": "angularidades-ops",
  "version": "1.0.0",
  "description": "Automated generation of summaries, chapters, and posts for the Angularidades podcast.",
  "main": "index.js",
  "bin": {
    "angularidades": "./bin/cli.js"
  },
  "scripts": {
    "youtube:publish": "node bin/cli.js publish",
    "youtube:dry-run": "node bin/cli.js publish --dry-run",
    "youtube:doctor": "node bin/cli.js doctor",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run bin/cli.e2e.spec.js",
    "prepare": "husky",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejandrocuba/angularidades-ops.git"
  },
  "keywords": [
    "angular",
    "podcast",
    "ai",
    "automation"
  ],
  "author": "Alejandro Cuba Ruiz",
  "license": "MIT",
  "engines": {
    "node": ">=26.0.0"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/alejandrocuba/angularidades-ops/issues"
  },
  "homepage": "https://github.com/alejandrocuba/angularidades-ops#readme",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "vitest": "^4.1.8"
  }
}
